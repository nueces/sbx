[sbx]
agent = "pi"
name = "pi"
image = "~/.smolvm/images/debian-sbx"
memory = 2048
cpus = 2
run_user = "agent"

# Mount this repo into the guest for testing.
project_path = "."
writable_mounts = true

# Keep the VM around after the first test run so you can inspect it.
stop_on_exit = false

# The image already contains Pi; do not copy host credentials by default.
copy_host_credentials = false
env = []
git_config = true

# Optional host-to-guest TCP forwards, applied when the VM starts.
# port_forwards = ["3000", "8080:3000", "0.0.0.0:3000:3000"]
